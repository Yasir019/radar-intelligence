# Groq Cloud API key — leave blank to run in demo mode (no live AI calls)
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-120b

# Force demo mode even if a key is set
DEMO_MODE=true

# Auth
JWT_SECRET=change-me-to-a-long-random-string

# Static API key for machine callers (n8n HTTP Request nodes send X-API-Key)
SERVICE_API_KEY=change-me-n8n-key

# Optional: n8n webhook URL (Flow C — instant alert fanout).
# Example: http://localhost:5678/webhook/radar-alerts
N8N_WEBHOOK_URL=

DATABASE_URL=sqlite:///./radar.db
